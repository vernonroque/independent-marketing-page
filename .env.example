# ── Backend ───────────────────────────────────────────────────────────────────
# URL of the deployed Python/FastAPI receipt parser backend
# Example: https://your-app.railway.app
RECEIPT_PARSER_API_URL=https://your-backend.railway.app

# API key used by the demo proxy to authenticate with the backend
# This key should have demo/read-only scope if your backend supports it
DEMO_API_KEY=your_demo_api_key_here

# ── reCAPTCHA (optional — not used on marketing site, kept for reference) ──────
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
